# Copy this file to .env.local and fill in both values.
# Find them in your Supabase dashboard: Project Settings > API.
# Both are safe for the browser (the publishable key is gated by RLS), and the
# same two values must be set as environment variables in your Vercel project.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
